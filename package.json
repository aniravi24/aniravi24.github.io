{
  "name": "nextra-blog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build && next-sitemap && touch out/.nojekyll && pnpm search-build",
    "search-build": "pagefind --site .next/server/app --output-path out/_pagefind",
    "dev": "next dev",
    "format": "prettier --write .",
    "start": "next start"
  },
  "dependencies": {
    "next": "16.2.9",
    "next-sitemap": "4.2.3",
    "nextra": "4.6.1",
    "nextra-theme-blog": "4.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "24.13.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "pagefind": "1.5.2",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@11.5.2"
}
